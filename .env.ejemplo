# Puerto donde corre tu servidor Express (para nosotros 3001)
PORT=xxxx

# Cadena de conexión a PostgreSQL
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/BASEDEDATOS
DATABASE_URL=postgres://xxxx:xxxx@localhost:5432/xxxx

# Loguin basico swagger, colocar siempre lo siguiente:
# BASIC_USER=usuario
# BASIC_PASS=clave
BASIC_USER=xxxx
BASIC_PASS=xxxx